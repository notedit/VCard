# Container-side env — copy to .env and fill from ~/.secrets/common.env
# (.env is gitignored; this .example lists key names only)

# === Plan / Edit / Suggestion via Anthropic native ===
# AIHubMix proxies Anthropic native API at the root path (no /v1)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://aihubmix.com

# === Pi Coding Agent SDK config ===
# Default model assignments per tech-design § 5.x
PLAN_MODEL=claude-sonnet-4-5
EDIT_MODEL=claude-haiku-4-5
SUGGESTION_MODEL=claude-haiku-4-5

# === Outbound to Workers internal API (for tool calls writing to DB) ===
# Set by AgentSession DO when starting the container
WORKERS_INTERNAL_BASE_URL=
WORKERS_INTERNAL_TOKEN=
